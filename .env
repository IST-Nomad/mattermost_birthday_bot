# Mattermost настройки
MATTERMOST_URL=http://your-mattermost-server:8065
MATTERMOST_TOKEN=your_bot_token_here
BOT_USERNAME=birthday_bot

# Каналы
ADMIN_CHANNEL_NAME=birthday-admin
NOTIFICATION_CHANNEL_NAME=general

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=birthday_bot
DB_USER=postgres
DB_PASSWORD=your_secure_password

# Время проверки дней рождения
CHECK_HOUR=9
CHECK_MINUTE=0